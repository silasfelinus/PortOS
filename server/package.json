    "sax": "1.4.4",
    "sharp": "0.34.5",
    "socket.io": "4.8.3",
    "socket.io-client": "4.8.3",
    "ws": "8.20.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.0.16",
    "vitest": "4.0.16"
  },
